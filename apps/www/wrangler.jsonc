{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "peculiar-charts-www",
  "main": "src/worker.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "none",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [{ "pattern": "charts.peculiarnewbie.com", "custom_domain": true }],
}
