{
  "name": "peculiar-charts-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter peculiar-charts build && pnpm --filter @peculiar-charts/www build",
    "build:lib": "pnpm --filter peculiar-charts build",
    "build:www": "pnpm --filter @peculiar-charts/www build",
    "dev": "pnpm --filter peculiar-charts build && pnpm --filter @peculiar-charts/www dev",
    "dev:www": "pnpm --filter @peculiar-charts/www dev",
    "deploy": "pnpm run build:www && pnpm --filter @peculiar-charts/www deploy",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --filter peculiar-charts build && pnpm --filter @peculiar-charts/www typecheck",
    "publish:lib": "pnpm --filter peculiar-charts release"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.10.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.0"
}
