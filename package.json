{
  "name": "peculiar-charts-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:lib": "pnpm --filter peculiar-charts build",
    "build:www": "pnpm --filter @peculiar-charts/www build",
    "dev": "turbo dev",
    "dev:www": "pnpm --filter @peculiar-charts/www dev",
    "deploy": "pnpm run build:www && pnpm --filter @peculiar-charts/www deploy",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.5.0"
}
